    {
      "name": "Add Todos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Parse the response at the very top\r",
              "//const response = pm.response.json();\r",
              "\r",
              "let response = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"todoID\", response.id);\r",
              "pm.environment.set(\"todoTitle\", response.title);\r",
              "\r",
              "// 2. Run your tests\r",
              "pm.test(\"Todo created successfully\", function() {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"response contains todo fields\", function() {\r",
              "    pm.expect(response).to.have.property(\"id\");\r",
              "    pm.expect(response).to.have.property(\"title\");\r",
              "    pm.expect(response).to.have.property(\"completed\");\r",
              "    pm.expect(response).to.have.property(\"userId\");\r",
              "});\r",
              "\r",
              "// 3. Set the environment variable (now it can read response.id!)\r",
              "pm.environment.set(\"todoID\", response.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"title\": \"{{todoTitle}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:3000/todos",
          "protocol": "http",
          "host": [
